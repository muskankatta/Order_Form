# ── Google OAuth ──────────────────────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Application type: Web application
# Authorised JS Origins: https://your-domain.com (and http://localhost:3000 for dev)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Slack Notifications ────────────────────────────────────────────────────
# Create at api.slack.com → Your Apps → Incoming Webhooks
VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Google Sheets Sync ────────────────────────────────────────────────────
# The spreadsheet ID from the Sheet URL: /spreadsheets/d/THIS_PART/edit
VITE_SHEETS_ID=YOUR_GOOGLE_SHEET_ID

# ── Deployment ────────────────────────────────────────────────────────────
# Set to /Order_Form/ for GitHub Pages with repo name Order_Form
# Set to / for Firebase / custom domain
VITE_BASE_PATH=/
